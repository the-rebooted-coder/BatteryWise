<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    tools:context=".BatteryLab">

    <!-- Ambient background layer -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.03"
        android:background="?attr/colorPrimary" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Activity Title -->
        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="56dp"
            android:layout_marginBottom="16dp"
            android:fontFamily="@font/productsansbold"
            android:text="Battery Lab"
            android:textColor="?attr/colorOnSurface"
            android:textSize="28sp" />

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="48dp">

            <LinearLayout
                android:id="@+id/lab_content_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">

                <!-- 1. Power Flow Card (Previously Hero) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_power_flow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="0dp"
                    tools:visibility="visible">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/productsansbold"
                                android:text="Power Flow"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/txt_wattage"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:fontFamily="@font/productsansbold"
                                android:text="0.0 W"
                                android:textColor="?attr/colorOnSurface"
                                android:textSize="24sp" />
                        </LinearLayout>

                        <ImageView
                            android:id="@+id/info_power_flow"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:alpha="0.4"
                            android:src="@drawable/baseline_info_24"
                            app:tint="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 2. Temperature Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_temp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="0dp"
                    tools:visibility="visible">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/productsansbold"
                                android:text="Temperature"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/txt_temp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:fontFamily="@font/productsansbold"
                                android:text="0.0 °C"
                                android:textColor="?attr/colorOnSurface"
                                android:textSize="24sp" />
                        </LinearLayout>

                        <ImageView
                            android:id="@+id/info_temp"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:alpha="0.4"
                            android:src="@drawable/baseline_info_24"
                            app:tint="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 3. Health Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_health"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="0dp"
                    tools:visibility="visible">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/productsansbold"
                                android:text="Hardware Health"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/txt_health"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:fontFamily="@font/productsansbold"
                                android:text="Good"
                                android:textColor="?attr/colorOnSurface"
                                android:textSize="24sp" />
                        </LinearLayout>

                        <ImageView
                            android:id="@+id/info_health"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:alpha="0.4"
                            android:src="@drawable/baseline_info_24"
                            app:tint="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 4. Voltage Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_voltage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="0dp"
                    tools:visibility="visible">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/productsansbold"
                                android:text="Current Voltage"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/txt_voltage"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:fontFamily="@font/productsansbold"
                                android:text="0.0 V"
                                android:textColor="?attr/colorOnSurface"
                                android:textSize="24sp" />
                        </LinearLayout>

                        <ImageView
                            android:id="@+id/info_voltage"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:alpha="0.4"
                            android:src="@drawable/baseline_info_24"
                            app:tint="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 5. Charging Source Info (Detailed Card) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_source"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="0dp"
                    tools:visibility="visible">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="20dp">

                        <ImageView
                            android:id="@+id/img_source_icon"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/baseline_start_24"
                            app:tint="?attr/colorPrimary" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/txt_source_type"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/productsansbold"
                                android:text="AC Charger"
                                android:textColor="?attr/colorOnSurface"
                                android:textSize="16sp" />

                            <TextView
                                android:id="@+id/txt_charge_status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/productsans"
                                android:text="Charging Rapidly"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textSize="13sp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Footer -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="48dp"
                    android:layout_marginBottom="24dp"
                    android:alpha="0.4"
                    android:fontFamily="@font/productsans"
                    android:text="Hardware Insights · SafeCharge Lab"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="11sp" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>
</FrameLayout>
