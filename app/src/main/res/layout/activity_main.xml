<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:ripple="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/coordinatorLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    tools:context=".MainActivity">

    <!-- ═══════════════════════════════════════════════ -->
    <!-- LAYER 1 · The Living Wave — full-screen canvas  -->
    <!-- ═══════════════════════════════════════════════ -->
    <me.itangqi.waveloadingview.WaveLoadingView
        android:id="@+id/waveLoadingView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="Battery level wave animation"
        app:wlv_borderColor="@color/md_theme_light_primary"
        app:wlv_borderWidth="0dp"
        app:wlv_shapeType="rectangle"
        app:wlv_waveAmplitude="18" />

    <!-- ═══════════════════════════════════════════════ -->
    <!-- LAYER 2 · Three-zone overlay                    -->
    <!-- ═══════════════════════════════════════════════ -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- ─────────────────────────────────────────── -->
        <!-- ZONE 1 · ZENITH BAR (top)                   -->
        <!-- ─────────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/zenithBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_marginTop="52dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="24dp"
            android:paddingEnd="8dp">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/topBarTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/productsansbold"
                android:text="SafeCharge"
                android:textColor="?attr/colorOnSurface"
                android:textSize="22sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_chronocell"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:contentDescription="ChronoCell battery history"
                app:icon="@drawable/ic_chronocell"
                app:iconSize="20dp"
                app:iconTint="?attr/colorOnSurfaceVariant" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_lab"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:contentDescription="Battery Lab diagnostics"
                app:icon="@drawable/ic_lab_flask"
                app:iconSize="20dp"
                app:iconTint="?attr/colorOnSurfaceVariant" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_settings"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:contentDescription="Settings"
                app:icon="@drawable/ic_settings_gear"
                app:iconSize="20dp"
                app:iconTint="?attr/colorOnSurfaceVariant" />

        </LinearLayout>

        <!-- ─────────────────────────────────────────── -->
        <!-- ZONE 2 · HERO CORE (center)                 -->
        <!-- ─────────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/heroCenterBlock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:layout_marginTop="-36dp"
            android:gravity="center"
            android:orientation="vertical">

            <!-- Giant battery percentage -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/heroBatteryNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/productsansbold"
                android:text="—%"
                android:textColor="#FFFFFF"
                android:textSize="86sp" />

            <!-- Dynamic contextual status line -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/heroSubLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="-4dp"
                android:fontFamily="@font/productsans"
                android:text="Current battery"
                android:textColor="#B3FFFFFF"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- ─────────────────────────────────────────── -->
        <!-- ZONE 3 · COMMAND DOCK (bottom)              -->
        <!-- ─────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_marginBottom="28dp"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <!-- ── ERROR STATE: Notifications Disabled ── -->
            <LinearLayout
                android:id="@+id/commandDockError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_error_card"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="20dp"
                android:visibility="gone"
                tools:visibility="gone">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_notification"
                    app:tint="@color/md_theme_dark_error" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/productsansbold"
                        android:text="Notifications Disabled"
                        android:textColor="@color/md_theme_dark_error"
                        android:textSize="15sp" />

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/productsans"
                        android:text="SafeCharge requires notifications to alert you. Tap to fix."
                        android:textColor="@color/md_theme_dark_errorContainer"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- ── IDLE STATE: Tap to start ── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/startBtn"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:contentDescription="Enable SafeCharge battery monitoring"
                android:fontFamily="@font/productsans"
                android:text="Enable SafeCharge"
                android:textAllCaps="false"
                android:textColor="?attr/colorOnPrimary"
                android:textSize="16sp"
                android:visibility="visible"
                app:backgroundTint="?attr/colorPrimary"
                app:cornerRadius="30dp" />

            <!-- ── ACTIVE STATE: Glass card + swipe to stop ── -->
            <LinearLayout
                android:id="@+id/commandDockActive"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                tools:visibility="visible">

                <!-- Info card (tappable → opens settings) -->
                <LinearLayout
                    android:id="@+id/dockInfoCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_glass_card"
                    android:clickable="true"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="20dp">

                    <!-- Pulsing live dot -->
                    <View
                        android:id="@+id/dockPulseDot"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:contentDescription="Monitoring active indicator"
                        android:background="@drawable/live_dot" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/dockStatusTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/productsansbold"
                            android:text="Monitoring"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/dockStatusSub"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="1dp"
                            android:fontFamily="@font/productsans"
                            android:text="Alert at 85%"
                            android:textColor="#99FFFFFF"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- SafeCharged counter badge -->
                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/dockSafechargedCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_glass_card"
                        android:fontFamily="@font/productsansbold"
                        android:paddingStart="12dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="6dp"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        tools:text="🛡 147" />
                </LinearLayout>
            </LinearLayout>

            <!-- Subtle branding footer -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/footerBranding"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:alpha="0.3"
                android:fontFamily="@font/productsans"
                android:text="SafeCharge"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />

        </LinearLayout>

    </RelativeLayout>

</FrameLayout>