<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/coordinatorLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    tools:context=".MainActivity">

    <!-- ═══════════════════════════════════════════════ -->
    <!-- LAYER 1 · The Living Wave — full-screen canvas  -->
    <!-- ═══════════════════════════════════════════════ -->
    <me.itangqi.waveloadingview.WaveLoadingView
        android:id="@+id/waveLoadingView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:wlv_borderColor="@color/md_theme_light_primary"
        app:wlv_borderWidth="0dp"
        app:wlv_shapeType="rectangle"
        app:wlv_waveAmplitude="18" />

    <!-- ═══════════════════════════════════════════════ -->
    <!-- LAYER 2 · Transparent overlay with all UI       -->
    <!-- ═══════════════════════════════════════════════ -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- ─── TOP BAR ─── -->
        <RelativeLayout
            android:id="@+id/topBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_marginTop="56dp"
            android:paddingStart="24dp"
            android:paddingEnd="16dp">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/topBarTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:fontFamily="@font/productsansbold"
                android:text="SafeCharge"
                android:textColor="?attr/colorOnSurface"
                android:textSize="22sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_lab"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                app:icon="@drawable/ic_lab_flask"
                app:iconSize="22dp"
                app:iconTint="?attr/colorOnSurfaceVariant" />

        </RelativeLayout>

        <!-- ─── CENTER BLOCK · hero number + labels ─── -->
        <LinearLayout
            android:id="@+id/heroCenterBlock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:layout_marginTop="-48dp"
            android:gravity="center"
            android:orientation="vertical">

            <!-- 80sp hero battery percentage -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/heroBatteryNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/productsansbold"
                android:text="—%"
                android:textColor="#FFFFFF"
                android:textSize="80sp" />

            <!-- "Current battery" subtitle -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/heroSubLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/productsans"
                android:text="Current battery"
                android:textColor="#B3FFFFFF"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- ─── BOTTOM BLOCK · pill + buttons + ghost link ─── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_marginBottom="24dp"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <!-- Action Buttons Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:gravity="center"
                android:orientation="horizontal">

                <!-- Status pill — animated in when monitoring starts -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/statusPill"
                    android:layout_width="wrap_content"
                    android:layout_height="56dp"
                    android:alpha="0"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:visibility="invisible"
                    app:cardBackgroundColor="?attr/colorPrimaryContainer"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/statusPillText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:fontFamily="@font/productsans"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:text="● Monitoring"
                        android:textColor="?attr/colorOnPrimaryContainer"
                        android:textSize="14sp" />
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Ghost settings link -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/settingsGhostLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/productsans"
                android:padding="8dp"
                android:text="≡  Settings"
                android:textColor="#66FFFFFF"
                android:textSize="13sp" />

            <!-- Enable SafeCharge button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/saveBatteryBtn"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:fontFamily="@font/productsans"
                android:text="Enable SafeCharge"
                android:textAllCaps="false"
                android:textColor="?attr/colorOnPrimary"
                android:textSize="16sp"
                app:backgroundTint="?attr/colorPrimary"
                app:cornerRadius="30dp" />

        </LinearLayout>

    </RelativeLayout>

</FrameLayout>