<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    tools:context=".ChronoCellActivity">

    <!-- Ambient background layer -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.03"
        android:background="?attr/colorPrimary" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ═══════════════════════════════════════ -->
        <!-- HERO HEADER                             -->
        <!-- ═══════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/chrono_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="56dp">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/chrono_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/productsansbold"
                android:text="ChronoCell"
                android:textColor="?attr/colorOnSurface"
                android:textSize="28sp" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/chrono_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/productsans"
                android:text="Your battery's story, over time"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="14sp" />

            <!-- Time Range Chip Group -->
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chrono_time_chips"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:selectionRequired="true"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_7d"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:fontFamily="@font/productsans"
                    android:text="7 Days"
                    android:textSize="13sp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_30d"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/productsans"
                    android:text="30 Days"
                    android:textSize="13sp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_all"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/productsans"
                    android:text="All Time"
                    android:textSize="13sp" />

            </com.google.android.material.chip.ChipGroup>

        </LinearLayout>

        <!-- ═══════════════════════════════════════ -->
        <!-- SCROLLABLE CONTENT                      -->
        <!-- ═══════════════════════════════════════ -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="48dp">

            <LinearLayout
                android:id="@+id/chrono_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">

                <!-- ─── 1. Temperature Trends Card ─── -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_temp_graph"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/productsansbold"
                            android:text="Temperature Trends"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="13sp" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/txt_temp_summary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="@font/productsans"
                            android:text="Charging temperature over time"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="11sp" />

                        <com.onesilicondiode.batterywise.ChronoGraphView
                            android:id="@+id/graph_temperature"
                            android:layout_width="match_parent"
                            android:layout_height="180dp"
                            android:layout_marginTop="12dp" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ─── 2. Battery Level Patterns Card ─── -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_level_graph"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/productsansbold"
                            android:text="Battery Level"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="13sp" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/txt_level_summary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="@font/productsans"
                            android:text="Battery percentage snapshots"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="11sp" />

                        <com.onesilicondiode.batterywise.ChronoGraphView
                            android:id="@+id/graph_battery_level"
                            android:layout_width="match_parent"
                            android:layout_height="180dp"
                            android:layout_marginTop="12dp" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ─── 3. Charge Sessions Card ─── -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_sessions_graph"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/productsansbold"
                            android:text="Charge Sessions"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="13sp" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/txt_sessions_summary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="@font/productsans"
                            android:text="End % reached per charge session"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="11sp" />

                        <com.onesilicondiode.batterywise.ChronoGraphView
                            android:id="@+id/graph_sessions"
                            android:layout_width="match_parent"
                            android:layout_height="180dp"
                            android:layout_marginTop="12dp" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ═══════════════════════════════════════ -->
                <!-- STATS GRID (2×2)                        -->
                <!-- ═══════════════════════════════════════ -->
                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginTop="24dp"
                    android:fontFamily="@font/productsansbold"
                    android:text="Lifetime Stats"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="18sp" />

                <!-- Row 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <!-- Total Charge Cycles -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_stat_cycles"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="18dp">

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/txt_stat_cycles_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/productsansbold"
                                android:text="Charge Cycles"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textSize="11sp" />

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/txt_stat_cycles"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:fontFamily="@font/productsansbold"
                                android:text="—"
                                android:textColor="?attr/colorOnSurface"
                                android:textSize="28sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Avg Charging Temp -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_stat_temp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="18dp">

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/productsansbold"
                                android:text="Avg Temp"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textSize="11sp" />

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/txt_stat_temp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:fontFamily="@font/productsansbold"
                                android:text="—"
                                android:textColor="?attr/colorOnSurface"
                                android:textSize="28sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- Row 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <!-- Hours Monitored -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_stat_hours"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="18dp">

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/txt_stat_hours_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/productsansbold"
                                android:text="Time Monitored"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textSize="11sp" />

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/txt_stat_hours"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:fontFamily="@font/productsansbold"
                                android:text="—"
                                android:textColor="?attr/colorOnSurface"
                                android:textSize="28sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- SafeCharged Count -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_stat_safecharged"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="18dp">

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/productsansbold"
                                android:text="SafeCharged"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textSize="11sp" />

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/txt_stat_safecharged"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:fontFamily="@font/productsansbold"
                                android:text="—"
                                android:textColor="?attr/colorOnSurface"
                                android:textSize="28sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- ═══════════════════════════════════════ -->
                <!-- PREDICTION CARD                         -->
                <!-- ═══════════════════════════════════════ -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_prediction"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    app:cardBackgroundColor="?attr/colorPrimaryContainer"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="20dp">

                        <!-- Circular progress ring (drawn programmatically) -->
                        <FrameLayout
                            android:layout_width="64dp"
                            android:layout_height="64dp">

                            <com.google.android.material.progressindicator.CircularProgressIndicator
                                android:id="@+id/progress_health"
                                android:layout_width="64dp"
                                android:layout_height="64dp"
                                android:layout_gravity="center"
                                app:indicatorColor="?attr/colorPrimary"
                                app:indicatorSize="60dp"
                                app:trackColor="?attr/colorSurfaceVariant"
                                app:trackThickness="6dp" />

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/txt_health_percent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:fontFamily="@font/productsansbold"
                                android:text="—"
                                android:textColor="?attr/colorOnPrimaryContainer"
                                android:textSize="16sp" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/productsansbold"
                                android:text="Battery Lifespan"
                                android:textColor="?attr/colorOnPrimaryContainer"
                                android:textSize="15sp" />

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/txt_prediction"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:fontFamily="@font/productsans"
                                android:text="Collecting data…"
                                android:textColor="?attr/colorOnPrimaryContainer"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ═══════════════════════════════════════ -->
                <!-- DATA LOCALITY NOTICE                    -->
                <!-- ═══════════════════════════════════════ -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_data_notice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:alpha="0.5"
                            android:src="@drawable/baseline_info_24"
                            app:tint="?attr/colorOnSurfaceVariant" />

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:fontFamily="@font/productsans"
                            android:text="All data stays on your device. A factory reset will erase this history permanently — it never leaves your phone."
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="12sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Footer -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="32dp"
                    android:layout_marginBottom="24dp"
                    android:alpha="0.4"
                    android:fontFamily="@font/productsans"
                    android:text="ChronoCell · Battery Time Machine"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="11sp" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </LinearLayout>

</FrameLayout>
